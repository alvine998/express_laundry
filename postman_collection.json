    {
      "name": "Courier",
      "description": "Endpoints for couriers. Requires Bearer token with role=courier.\n\n--- Socket.io Events (courier side) ---\nEMIT   | accept_order        | { token, orderId }\nLISTEN | order_accept_result | { orderId, success, reason? }\nLISTEN | new_order_offer     | { orderId, shopName, shopAddress, location: {lat,lon}, timeoutSeconds }\n\n--- Socket.io Events (customer side) ---\nLISTEN | courier_searching   | { orderId }\nLISTEN | courier_assigned    | { orderId, courier: {id, name, phone} }\nLISTEN | courier_not_found   | { orderId, reason? }\nLISTEN | status_changed      | { orderId, newStatus }",
      "item": [
        {
          "name": "Get Courier Orders",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/api/courier/orders?page=1&limit=10",
              "host": ["{{base_url}}"],
              "path": ["api", "courier", "orders"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "status", "value": "PICKING_UP", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Update Courier Order Status",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/api/courier/orders/ORD-1234567890-123/status",
              "host": ["{{base_url}}"],
              "path": ["api", "courier", "orders", "ORD-1234567890-123", "status"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"PICKING_UP\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Allowed statuses: PICKING_UP, DELIVERING, COMPLETED"
          }
        }
      ]
    }
  ]
}
